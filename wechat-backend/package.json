{
  "name": "wewe-rss",
  "version": "2.6.1",
  "private": true,
  "author": "cooderl <cooder@111965.xyz>",
  "description": "",
  "main": "index.js",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=8.6.1",
    "vscode": ">=1.79"
  },
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "build:server": "pnpm --filter server build",
    "build:web": "pnpm --filter web build",
    "start:server": "pnpm --filter server start:prod",
    "start:web": "pnpm --filter web start",
    "wiki:run": "node ./scripts/llm-wiki-run.mjs",
    "wiki:backfill": "node ./scripts/llm-wiki-backfill.mjs",
    "wiki:lint": "node ./scripts/llm-wiki-lint.mjs",
    "wiki:render:month": "node ./scripts/llm-wiki-render-month.mjs",
    "wiki:glm:probe": "node ./scripts/llm-wiki-glm-probe.mjs",
    "wiki:glm:estimate": "node ./scripts/llm-wiki-glm-estimate.mjs",
    "wiki:glm:run": "node ./scripts/llm-wiki-glm-run.mjs",
    "wiki:pdf:install": "playwright install chromium",
    "wiki:pdf:login": "node ./scripts/llm-wiki-pdf-login.mjs",
    "wiki:pdf:sync": "node ./scripts/llm-wiki-pdf-sync.mjs",
    "wiki:pdf:attach": "node ./scripts/llm-wiki-pdf-attach.mjs",
    "wiki:pdf:sync:run": "powershell -ExecutionPolicy Bypass -File ./scripts/run-llm-wiki-pdf-sync.ps1 -All",
    "wiki:pdf:sync:install": "powershell -ExecutionPolicy Bypass -File ./scripts/manage-llm-wiki-pdf-sync-task.ps1 -Action Install",
    "wiki:pdf:sync:status": "powershell -ExecutionPolicy Bypass -File ./scripts/manage-llm-wiki-pdf-sync-task.ps1 -Action Status",
    "wiki:pdf:sync:run-now": "powershell -ExecutionPolicy Bypass -File ./scripts/manage-llm-wiki-pdf-sync-task.ps1 -Action RunNow",
    "wiki:pdf:sync:uninstall": "powershell -ExecutionPolicy Bypass -File ./scripts/manage-llm-wiki-pdf-sync-task.ps1 -Action Uninstall",
    "wiki:setup:local": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-local-llm-wiki-runtime.ps1",
    "archive:obsidian": "node ./scripts/obsidian-archive.mjs",
    "archive:obsidian:once": "node ./scripts/obsidian-archive-worker.mjs --once",
    "archive:obsidian:worker": "node ./scripts/obsidian-archive-worker.mjs",
    "archive:obsidian:repair-feed": "node ./scripts/obsidian-archive-worker.mjs --once --repair-feed-sourced",
    "archive:obsidian:repair-all": "powershell -ExecutionPolicy Bypass -File ./scripts/run-z001-obsidian-archive-repair-all-detached.ps1",
    "archive:obsidian:repair-all:run": "powershell -ExecutionPolicy Bypass -File ./scripts/run-z001-obsidian-archive-repair-all-detached.ps1",
    "archive:obsidian:repair-all:status": "powershell -ExecutionPolicy Bypass -File ./scripts/check-z001-obsidian-archive-repair-all-status.ps1",
    "archive:obsidian:repair-all:detached": "powershell -ExecutionPolicy Bypass -File ./scripts/run-z001-obsidian-archive-repair-all-detached.ps1",
    "archive:obsidian:repair-all:detached:status": "powershell -ExecutionPolicy Bypass -File ./scripts/check-z001-obsidian-archive-repair-all-status.ps1",
    "archive:obsidian:status": "powershell -ExecutionPolicy Bypass -File ./scripts/check-z001-obsidian-archive-status.ps1",
    "archive:obsidian:mirror:install": "powershell -ExecutionPolicy Bypass -File ./scripts/manage-z001-obsidian-mirror-task.ps1 -Action Install",
    "archive:obsidian:mirror:status": "powershell -ExecutionPolicy Bypass -File ./scripts/manage-z001-obsidian-mirror-task.ps1 -Action Status",
    "archive:obsidian:mirror:run": "powershell -ExecutionPolicy Bypass -File ./scripts/manage-z001-obsidian-mirror-task.ps1 -Action RunNow",
    "archive:obsidian:mirror:uninstall": "powershell -ExecutionPolicy Bypass -File ./scripts/manage-z001-obsidian-mirror-task.ps1 -Action Uninstall",
    "archive:obsidian:mirror:startup:install": "powershell -ExecutionPolicy Bypass -File ./scripts/manage-z001-obsidian-mirror-agent-startup.ps1 -Action Install",
    "archive:obsidian:mirror:startup:status": "powershell -ExecutionPolicy Bypass -File ./scripts/manage-z001-obsidian-mirror-agent-startup.ps1 -Action Status",
    "archive:obsidian:mirror:startup:run": "powershell -ExecutionPolicy Bypass -File ./scripts/manage-z001-obsidian-mirror-agent-startup.ps1 -Action RunNow",
    "archive:obsidian:mirror:startup:uninstall": "powershell -ExecutionPolicy Bypass -File ./scripts/manage-z001-obsidian-mirror-agent-startup.ps1 -Action Uninstall",
    "test:llm-wiki": "node --test ./scripts/llm-wiki.test.mjs",
    "test:obsidian-archive": "node --test ./scripts/obsidian-archive.test.mjs",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check ."
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "prettier": "^3.2.5"
  }
}
